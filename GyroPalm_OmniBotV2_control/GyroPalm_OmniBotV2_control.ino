void pulse_on( unsigned long duration ) {
    unsigned long stop = micros() + duration;
    while( micros() < stop ) {
        digitalWrite(ir_pin, HIGH );
        delayMicroseconds( 13 );
        digitalWrite(ir_pin, LOW );
        delayMicroseconds( 13 );
    }
}
void pulse_off( unsigned long duration ) {
    unsigned long stop = micros() + duration;
    while( micros() < stop );
}
void nikonCapture()
{
    for (int i=0; i < 2; i++) {
        pulse_on(2000);
        pulse_off(27850);
        pulse_on(390);
        pulse_off(1580);
        pulse_on(410);
        pulse_off(3580);
        pulse_on(400);
        pulse_off(63200);
    }
    lv_disp_trig_activity(NULL);    //reset inactivity counter
}

