static void btn_event_handler(lv_obj_t * obj, lv_event_t event)
{
    if (event == LV_EVENT_CLICKED) {
        String btnName = lv_list_get_btn_text(obj);
    Serial.printf("Clicked: %s\n", btnName);

        switch (curScreen)
        {
            case SCR_HOME:
                if (btnName == "Undock") {
                    sendDockCommand(true);  //undock
                    showMsg("Undock sent!");
                }
                else if (btnName == "Dock") {
                    sendDockCommand(false);  //dock
                    showMsg("Dock sent!");
                }
                else if (btnName == "Flip") {
                    flipMode = !flipMode;
                    if (flipMode) {
                        showMsg("Flip Mode ON!");
                    } else {
                        showMsg("Flip Mode OFF!");
                    }
                }
                else if (btnName == "Uturn") {
                    sendUturnCommand();
                    showMsg("Uturn sent!");
                }
                else if (btnName == "AMR V2") { // 0 is AMR, 1 is omni, 2 is vortex, 3 is DSLR, 4 is maze
                    targetDevice = 0;
                    showMsg("AMR V2 selected!");
                }
                else if (btnName == "Omni") {
                    targetDevice = 1;
                    showMsg("OmniBot selected!");
                }
                else if (btnName == "Vortex") {
                    targetDevice = 2;
                    showMsg("Vortex selected!");
                }
                else if (btnName == "DSLR") {
                    targetDevice = 3;
                    showMsg("DSLR selected!");
                } 
                else if (btnName == "Maze") {
                    targetDevice = 4;
                    showMsg("Maze selected!");
                } else {
                    
                }
            break;

            default: break;
    }
  } else if (event == LV_EVENT_LONG_PRESSED) {
        String btnName = lv_list_get_btn_text(obj);
    Serial.printf("Long Pressed: %s\n", btnName);

        if (btnName == "Hold to Activate") {
            form[curScreen].removeDropdown();
            lv_task_handler();
            gplm.vibratePress();
            setDriving(true);   //send start driving intent
        }
    }
}

